{
  "expo": {
    "name": "Fahrtdoc",
    "slug": "fahrtdoc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fahrtdoc",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fahrtdoc.app"
    },
    "android": {
      "package": "com.fahrtdoc.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "DriveLog benötigt deinen Standort, um Fahrten zu erfassen.",
          "locationWhenInUsePermission": "DriveLog benötigt deinen Standort, um Fahrten zu erfassen."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}