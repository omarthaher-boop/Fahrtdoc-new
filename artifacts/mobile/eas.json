{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development-device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://f6b49634-ba25-46e4-a4ef-a83e890a9075-00-hsre8wwzxwlj.janeway.replit.dev/api",
        "GOOGLE_MAPS_ANDROID_API_KEY": "$GOOGLE_MAPS_ANDROID_API_KEY"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://f6b49634-ba25-46e4-a4ef-a83e890a9075-00-hsre8wwzxwlj.janeway.replit.dev/api",
        "GOOGLE_MAPS_ANDROID_API_KEY": "$GOOGLE_MAPS_ANDROID_API_KEY"
      },
      "node": {
        "pnpm": {
          "frozen": false
        }
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6774674056"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
