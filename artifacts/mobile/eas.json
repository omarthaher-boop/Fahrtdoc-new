{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development-device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fahrtdoc-new-production.up.railway.app/api",
        "GOOGLE_MAPS_ANDROID_API_KEY": "$GOOGLE_MAPS_ANDROID_API_KEY",
        "GOOGLE_MAPS_IOS_API_KEY": "$GOOGLE_MAPS_IOS_API_KEY"
      }
    },
    "production": {
      "prebuildCommand": "prebuild --clean --no-install",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium",
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fahrtdoc-new-production.up.railway.app/api",
        "GOOGLE_MAPS_ANDROID_API_KEY": "$GOOGLE_MAPS_ANDROID_API_KEY",
        "GOOGLE_MAPS_IOS_API_KEY": "$GOOGLE_MAPS_IOS_API_KEY",
        "EXPO_PUBLIC_REVENUECAT_IOS_API_KEY": "$EXPO_PUBLIC_REVENUECAT_IOS_API_KEY",
        "EXPO_PUBLIC_REVENUECAT_TEST_API_KEY": "$EXPO_PUBLIC_REVENUECAT_TEST_API_KEY"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6774674056"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
